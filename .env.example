# Ambiente
ENVIRONMENT=development

# Provedor de IA (ollama ou openai)
AI_PROVIDER=ollama

# OpenAI (se usar)
OPENAI_API_KEY=sua-chave-aqui
OPENAI_MODEL=gpt-3.5-turbo

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Configurações de IA
MAX_TOKENS=500
TEMPERATURE=0.7

# CORS - origens permitidas (separadas por vírgula)
# Em produção: URL do Vercel e, após Fase 2, a origem da extensão Chrome
# Exemplo: ALLOWED_ORIGINS=https://seu-app.vercel.app,chrome-extension://ID_DA_EXTENSAO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173